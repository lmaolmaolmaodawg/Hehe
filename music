    local function updateVolume()
        if currentSound then
            currentSound.Volume = currentVolume
        end
    end

    local function stopCurrentSound()
        if currentSound then
            currentSound:Stop()
            currentSound:Destroy()
            currentSound = nil
            isPlaying = false
            isPaused = false
            playlistActive = false
            currentSoundId = ""
            if nowPlayingLabel then
                nowPlayingLabel.Text = "Now Playing: None"
            end
            if currentPlayButton then
                currentPlayButton.Text = "Play"
            end
            currentPlayButton = nil
        end
    end

    local function pauseCurrentSound()
        if currentSound and isPlaying then
            currentSound:Pause()
            isPlaying = false
            isPaused = true
            if currentPlayButton then
                currentPlayButton.Text = "Resume"
            end
        end
    end

    local function resumeCurrentSound()
        if currentSound and isPaused then
            currentSound:Resume()
            isPlaying = true
            isPaused = false
            if currentPlayButton then
                currentPlayButton.Text = "Pause"
            end
        end
    end

    local function playSoundById(id, loop, playButton)
        if currentSound and currentSoundId == id and isPlaying then
            pauseCurrentSound()
            return
        end

        if currentSound and currentSoundId == id and isPaused then
            resumeCurrentSound()
            return
        end

        stopCurrentSound()

        local sound = Instance.new("Sound")
        sound.SoundId = "rbxassetid://" .. id
        sound.Parent = SoundService
        sound.Volume = currentVolume
        sound.Looped = loop or false

        sound:Play()
        currentSound = sound
        isPlaying = true
        isPaused = false
        currentSoundId = id
        currentPlayButton = playButton

        if playButton then
            playButton.Text = "Pause"
        end

        sound.Stopped:Connect(function()
            isPlaying = false
            isPaused = false
            if currentPlayButton then
                currentPlayButton.Text = "Play"
            end
            if loop then
                sound:Play()
            elseif playlistActive and isPlaylistLooping then
                playNextInPlaylist()
            end
        end)

        return sound
    end

    local function playNextInPlaylist()
        if not playlistActive then return end

        currentPlaylistIndex = currentPlaylistIndex + 1
        if currentPlaylistIndex > #playlist then
            if isPlaylistLooping then
                currentPlaylistIndex = 1
            else
                playlistActive = false
                nowPlayingLabel.Text = "Now Playing: None"
                return
            end
        end

        local song = playlist[currentPlaylistIndex]
        nowPlayingLabel.Text = "Now Playing: " .. song.name
        playSoundById(song.id, false)
        createNotify("Playing: " .. song.name)
    end

    local function startPlaylist()
        stopCurrentSound()
        currentPlaylistIndex = 1
        playlistActive = true
        isPlaylistLooping = true -- Set loop to true by default so it repeats
        if loopPlaylistButton then
            loopPlaylistButton.Text = "Loop ON"
