        end)

        loopIdBtn.MouseButton1Click:Connect(function()
            if idInput.Text ~= "" then
                soundIdLoopActive = not soundIdLoopActive
                loopIdBtn.BackgroundColor3 = soundIdLoopActive and Color3.fromRGB(0, 150, 40) or Color3.fromRGB(180, 70, 25)
                loopIdBtn.Text = soundIdLoopActive and "ON" or "Loop"
                if soundIdLoopActive then
                    playlistActive = false
                    nowPlayingLabel.Text = "Now Playing (Loop ID)"
                    playSoundById(idInput.Text, true, playOnceBtn)
                    createNotify("Looping ID: " .. idInput.Text)
                else
                    if currentSound and currentSoundId == idInput.Text then
                        stopCurrentSound()
                        playOnceBtn.Text = "Play"
                        nowPlayingLabel.Text = "Now Playing: None"
                    end
                end
            end
        end)

        stopIdBtn.MouseButton1Click:Connect(function()
            stopCurrentSound()
            soundIdLoopActive = false
            loopIdBtn.BackgroundColor3 = Color3.fromRGB(180, 70, 25)
            loopIdBtn.Text = "Loop"
            playOnceBtn.Text = "Play"
            createNotify("Stopped ID")
        end)

        yOffset = yOffset + 65

        local noteFrame = Instance.new("Frame")
        noteFrame.Parent = contentFrame
        noteFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
        noteFrame.Position = UDim2.new(0, 0, 0, yOffset)
        noteFrame.Size = UDim2.new(1, 0, 0, 40)

        local noteCorner = Instance.new("UICorner")
        noteCorner.Parent = noteFrame
        noteCorner.CornerRadius = UDim.new(0, 3)

        local noteLabel = Instance.new("TextLabel")
        noteLabel.Parent = noteFrame
        noteLabel.BackgroundTransparency = 1
        noteLabel.Position = UDim2.new(0, 4, 0, 2)
        noteLabel.Size = UDim2.new(1, -8, 0, 36)
        noteLabel.Text = "Notes: Once script is executed it auto starts playlist, so click Stop Playlist to stop it if you wanna!"
        noteLabel.TextColor3 = Color3.fromRGB(200, 200, 220)
        noteLabel.TextSize = 8
        noteLabel.TextWrapped = true
        noteLabel.Font = Enum.Font.Gotham
        noteLabel.TextXAlignment = Enum.TextXAlignment.Left

        contentFrame.CanvasSize = UDim2.new(0, 0, 0, yOffset + 45)
    end

    createButtons()

    local dragging = false
    local dragStart, startPos

    local function startDrag(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if input.Position.Y >= mainFrame.AbsolutePosition.Y and input.Position.Y <= mainFrame.AbsolutePosition.Y + 25 then
                dragging = true
                dragStart = input.Position
                startPos = mainFrame.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        dragging = false
                    end
                end)
            end
        end
    end

    local function updateDrag(input)
        if dragging then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end

    UserInputService.InputBegan:Connect(startDrag)
    UserInputService.InputChanged:Connect(updateDrag)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    task.wait(0.5)
    startPlaylist()

    return screenGui
end

createMainGUI()
